<template>
  <view class="page">
    <view v-if="loading" class="loading">加载中...</view>
    <template v-else-if="article">
      <image v-if="article.cover_image" :src="article.cover_image" mode="aspectFill" class="cover" />
      <view class="content">
        <view class="title">{{ article.title }}</view>
        <view class="meta">
          <text>{{ article.category }}</text>
          <text>{{ article.view_count }} 阅读</text>
          <text>{{ formatDate(article.created_at) }}</text>
        </view>
        <view class="body">
          <rich-text :nodes="article.content"></rich-text>
        </view>
        <view v-if="article.ai_generated" class="ai-badge">
          <text>🤖 本文由AI辅助生成</text>
        </view>
      </view>
    </template>
    <view v-else class="empty">
      <text>文章不存在</text>
    </view>
  </view>
</template>

<script setup>
import { ref, onMounted } from 'vue';
import baas from '@/common/baas-sdk';

const article = ref(null);
const loading = ref(true);

onMounted(() => {
  const pages = getCurrentPages();
  const currentPage = pages[pages.length - 1];
  const id = currentPage.options?.id;
  if (id) loadArticle(parseInt(id));
});

async function loadArticle(id) {
  try {
    article.value = await baas.getArticle(id);
  } catch {
    uni.showToast({ title: '加载文章失败', icon: 'none' });
  } finally {
    loading.value = false;
  }
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}
</script>

