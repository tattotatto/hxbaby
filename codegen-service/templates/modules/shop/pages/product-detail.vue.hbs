<template>
  <view class="page">
    <view v-if="loading" class="loading">加载中...</view>
    <template v-else-if="product">
      <!-- Image carousel -->
      <swiper class="swiper" indicator-dots indicator-color="#ccc" indicator-active-color="{{primaryColor}}" autoplay circular>
        <swiper-item v-for="(img,idx) in images" :key="idx">
          <image :src="img" mode="aspectFill" class="swiper-img"/>
        </swiper-item>
      </swiper>

      <!-- Product info -->
      <view class="info-section">
        <view class="p-name">{{product.name}}</view>
        <view class="p-price-row">
          <text class="price">¥{{product.price}}</text>
          <text v-if="product.original_price" class="orig-price">¥{{product.original_price}}</text>
        </view>
        <!-- AI tags -->
        <view v-if="aiTags.length" class="ai-tags">
          <text v-for="tag in aiTags" :key="tag" class="ai-tag">✨ {{tag}}</text>
        </view>
        <!-- AI selling points -->
        <view v-if="product.ai_selling_points" class="ai-points">
          <view class="ai-points-title">AI推荐理由</view>
          <view v-for="(pt,i) in sellingPoints" :key="i" class="ai-point-item">
            <text class="point-dot">•</text>
            <text>{{pt}}</text>
          </view>
        </view>
      </view>

      <!-- Quantity selector -->
      <view class="qty-section">
        <text class="qty-label">数量</text>
        <view class="qty-stepper">
          <view class="qty-btn" :class="{disabled:qty<=1}" @tap="changeQty(-1)">-</view>
          <text class="qty-val">{{qty}}</text>
          <view class="qty-btn" @tap="changeQty(1)">+</view>
        </view>
      </view>

      <!-- Description -->
      <view class="desc-section">
        <view class="section-title">商品详情</view>
        <view class="desc-body">
          <rich-text :nodes="product.description||'暂无详情'"></rich-text>
        </view>
      </view>

      <!-- Bottom bar -->
      <view class="bottom-bar">
        <button class="btn-cart" @tap="addToCart">加入购物车</button>
        <button class="btn-buy" @tap="buyNow">立即购买</button>
      </view>
    </template>
    <view v-else class="empty">
      <text>商品不存在</text>
    </view>
  </view>
</template>

<script setup>
import {ref, computed, onMounted} from 'vue';
import baas from '@/common/baas-sdk';

const product=ref(null);
const loading=ref(true);
const qty=ref(1);

const images=computed(()=>{
  if(!product.value?.images) return ['/static/placeholder.png'];
  try{return JSON.parse(product.value.images);}catch{return [product.value.images];}
});
const aiTags=computed(()=>{
  if(!product.value?.ai_tags) return [];
  try{return typeof product.value.ai_tags==='string'?JSON.parse(product.value.ai_tags):product.value.ai_tags;}catch{return [];}
});
const sellingPoints=computed(()=>{
  if(!product.value?.ai_selling_points) return [];
  try{return typeof product.value.ai_selling_points==='string'?JSON.parse(product.value.ai_selling_points):product.value.ai_selling_points;}catch{return [];}
});

onMounted(()=>{
  const pages=getCurrentPages();
  const id=pages[pages.length-1].options?.id;
  if(id) loadProduct(parseInt(id));
});

async function loadProduct(id){
  try{product.value=await baas.getProduct(id);}
  catch{uni.showToast({title:'加载失败',icon:'none'});}
  finally{loading.value=false;}
}
function changeQty(d){qty.value=Math.max(1,qty.value+d);}
function addToCart(){
  uni.showToast({title:'已加入购物车',icon:'success'});
}
async function buyNow(){
  try{
    await baas.createOrder({product_id:product.value.id, quantity:qty.value});
    uni.showToast({title:'下单成功',icon:'success'});
  }catch{uni.showToast({title:'下单失败',icon:'none'});}
}
</script>

<style scoped>
.page{background:#f5f5f5; min-height:100vh; padding-bottom:60px;}
.loading,.empty{text-align:center; padding:60px 0; color:#999;}
.swiper{width:100%; height:300px;}
.swiper-img{width:100%; height:100%;}
.info-section{background:#fff; padding:16px; margin-bottom:8px;}
.p-name{font-size:18px; font-weight:700; color:#333; line-height:1.4;}
.p-price-row{display:flex; align-items:baseline; gap:8px; margin-top:10px;}
.price{font-size:22px; font-weight:700; color:{{primaryColor}};}
.orig-price{font-size:14px; color:#ccc; text-decoration:line-through;}
.ai-tags{display:flex; flex-wrap:wrap; gap:6px; margin-top:10px;}
.ai-tag{font-size:11px; padding:2px 10px; background:#f5f0ff; color:#7c4dff; border-radius:4px;}
.ai-points{margin-top:12px; padding:12px; background:#fafafa; border-radius:8px;}
.ai-points-title{font-size:13px; font-weight:600; color:#7c4dff; margin-bottom:6px;}
.ai-point-item{font-size:13px; color:#666; line-height:1.6; display:flex; gap:6px;}
.point-dot{color:{{primaryColor}};}
.qty-section{display:flex; justify-content:space-between; align-items:center; padding:14px 16px; background:#fff; margin-bottom:8px;}
.qty-label{font-size:15px; color:#333;}
.qty-stepper{display:flex; align-items:center; gap:12px;}
.qty-btn{width:28px; height:28px; border-radius:50%; background:#f5f5f5; display:flex; align-items:center; justify-content:center; font-size:18px; color:#333;}
.qty-btn.disabled{color:#ccc;}
.qty-val{font-size:16px; font-weight:600; min-width:24px; text-align:center;}
.desc-section{background:#fff; padding:16px; margin-bottom:8px;}
.section-title{font-size:16px; font-weight:600; color:#333; margin-bottom:12px; padding-bottom:8px; border-bottom:2px solid {{primaryColor}}; display:inline-block;}
.desc-body{font-size:14px; line-height:1.8; color:#666;}
.bottom-bar{position:fixed; bottom:0; left:0; right:0; display:flex; gap:10px; padding:10px 16px; background:#fff; border-top:1px solid #f0f0f0;}
.btn-cart{flex:1; height:44px; border-radius:22px; background:{{secondaryColor}}; color:#fff; font-size:15px; border:none; line-height:44px;}
.btn-buy{flex:1; height:44px; border-radius:22px; background:{{primaryColor}}; color:#fff; font-size:15px; border:none; line-height:44px;}
</style>
