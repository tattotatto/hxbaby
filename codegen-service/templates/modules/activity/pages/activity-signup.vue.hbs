<template>
  <view class="page">
    <view v-if="loading" class="loading">加载中...</view>
    <template v-else>
      <!-- Activity summary -->
      <view class="activity-summary">
        <image :src="activity.cover_image||activity.poster||'/static/placeholder.png'" mode="aspectFill" class="summary-img"/>
        <view class="summary-info">
          <view class="summary-title">{{activity.title}}</view>
          <view class="summary-time">{{formatDate(activity.start_time)}}</view>
        </view>
      </view>

      <!-- Signup form -->
      <view class="form-section">
        <view class="form-title">报名信息</view>
        <view class="form-item">
          <text class="label">姓名 <text class="required">*</text></text>
          <input v-model="form.name" class="input" placeholder="请输入姓名"/>
        </view>
        <view class="form-item">
          <text class="label">手机号 <text class="required">*</text></text>
          <input v-model="form.phone" class="input" type="number" placeholder="请输入手机号" maxlength="11"/>
        </view>
        <view class="form-item">
          <text class="label">备注</text>
          <textarea v-model="form.remark" class="textarea" placeholder="如有特殊需求可在此备注（选填）"/>
        </view>
      </view>

      <!-- Submit -->
      <view class="submit-wrap">
        <button class="submit-btn" :disabled="!canSubmit||submitting" @tap="doSignup">
          {{submitting?'提交中...':'确认报名'}}
        </button>
      </view>
    </template>
  </view>
</template>

<script setup>
import {ref, computed, onMounted} from 'vue';
import baas from '@/common/baas-sdk';

const activity=ref({});
const loading=ref(true);
const submitting=ref(false);
const form=ref({name:'',phone:'',remark:''});

const canSubmit=computed(()=>form.value.name.trim()&&/^1\d{10}$/.test(form.value.phone));

onMounted(()=>{
  const pages=getCurrentPages();
  const id=pages[pages.length-1].options?.id;
  if(id) loadActivity(parseInt(id));
});

async function loadActivity(id){
  try{activity.value=await baas.getActivity(id);}
  catch{uni.showToast({title:'加载活动失败',icon:'none'});}
  finally{loading.value=false;}
}

async function doSignup(){
  if(!canSubmit.value||submitting.value) return;
  if(!/^1\d{10}$/.test(form.value.phone)) return uni.showToast({title:'请输入正确的手机号',icon:'none'});
  submitting.value=true;
  try{
    const pages=getCurrentPages();
    const id=pages[pages.length-1].options?.id;
    await baas.signupActivity(id,{name:form.value.name,phone:form.value.phone,remark:form.value.remark});
    uni.showToast({title:'报名成功',icon:'success'});
    setTimeout(()=>uni.navigateBack(),1500);
  }catch{uni.showToast({title:'报名失败，请重试',icon:'none'});}
  finally{submitting.value=false;}
}

function formatDate(d){if(!d)return'';const dt=new Date(d);return`${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;}
</script>

<style scoped>
.page{background:#f5f5f5; min-height:100vh;}
.loading{text-align:center; padding:60px 0; color:#999;}
.activity-summary{display:flex; background:#fff; padding:12px; margin:8px; border-radius:12px; gap:10px; align-items:center;}
.summary-img{width:72px; height:72px; border-radius:8px;}
.summary-info{flex:1;}
.summary-title{font-size:15px; font-weight:600; color:#333; margin-bottom:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;}
.summary-time{font-size:13px; color:#999;}
.form-section{background:#fff; margin:8px; border-radius:12px; padding:16px;}
.form-title{font-size:16px; font-weight:600; color:#333; margin-bottom:16px;}
.form-item{margin-bottom:14px;}
.label{display:block; font-size:14px; color:#333; margin-bottom:6px;}
.required{color:#f44336;}
.input{width:100%; height:44px; background:#f5f5f5; border-radius:8px; padding:0 12px; font-size:14px; box-sizing:border-box;}
.textarea{width:100%; height:80px; background:#f5f5f5; border-radius:8px; padding:10px 12px; font-size:14px; box-sizing:border-box;}
.submit-wrap{padding:20px 16px;}
.submit-btn{width:100%; height:48px; border-radius:24px; background:{{primaryColor}}; color:#fff; font-size:16px; font-weight:600; border:none; line-height:48px;}
.submit-btn[disabled]{background:#ccc;}
</style>
