<template>
  <view class="chat-page">
    <!-- Messages -->
    <scroll-view
      scroll-y
      class="message-list"
      :scroll-top="scrollTop"
      :scroll-with-animation="true"
    >
      <view v-if="messages.length === 0" class="welcome">
        <image src="/static/ai-avatar.png" mode="aspectFit" class="ai-avatar" />
        <text class="welcome-title">AI健康顾问</text>
        <text class="welcome-sub">我是您的专属儿童健康顾问\n可以问我关于宝宝健康、喂养、发育等方面的问题</text>
      </view>

      <view
        v-for="msg in messages"
        :key="msg.id"
        class="message-row"
        :class="msg.role"
      >
        <view v-if="msg.role === 'assistant'" class="avatar ai-avatar-sm">
          <text>🤖</text>
        </view>
        <view class="bubble" :class="msg.role">
          <text>{{ msg.content }}</text>
        </view>
        <view v-if="msg.role === 'user'" class="avatar user-avatar-sm">
          <text>👤</text>
        </view>
      </view>

      <view v-if="isTyping" class="message-row assistant">
        <view class="avatar ai-avatar-sm">
          <text>🤖</text>
        </view>
        <view class="bubble assistant typing">
          <text>正在思考...</text>
        </view>
      </view>
    </scroll-view>

    <!-- Quick questions -->
    <view v-if="messages.length === 0" class="quick-questions">
      <view
        v-for="q in quickQuestions"
        :key="q"
        class="quick-btn"
        @tap="sendMessage(q)"
      >
        {{ q }}
      </view>
    </view>

    <!-- Disclaimer -->
    <view class="disclaimer">
      <text>⚠️ AI建议仅供参考，不能替代专业医疗诊断。如有紧急情况请及时就医。</text>
    </view>

    <!-- Input bar -->
    <view class="input-bar">
      <input
        v-model="inputText"
        class="input"
        placeholder="输入您的问题..."
        :disabled="isTyping"
        @confirm="sendMessage(inputText)"
      />
      <button
        class="send-btn"
        :disabled="!inputText.trim() || isTyping"
        @tap="sendMessage(inputText)"
      >
        发送
      </button>
    </view>
  </view>
</template>

<script setup>
import { ref, nextTick, onMounted } from 'vue';
import baas from '@/common/baas-sdk';

const messages = ref([]);
const inputText = ref('');
const isTyping = ref(false);
const scrollTop = ref(0);

const quickQuestions = [
  '宝宝消化不好怎么办？',
  '婴儿几个月开始添加辅食？',
  '儿童发烧38度需要吃药吗？',
  '如何判断宝宝是否缺钙？',
];

let msgId = 0;

function scrollToBottom() {
  nextTick(() => {
    scrollTop.value = scrollTop.value + 10000;
  });
}

async function sendMessage(text) {
  if (!text.trim() || isTyping.value) return;
  const userMsg = { id: ++msgId, role: 'user', content: text.trim() };
  messages.value.push(userMsg);
  inputText.value = '';
  scrollToBottom();

  isTyping.value = true;
  try {
    const data = await baas.aiChat(text.trim(), null);
    const aiMsg = {
      id: ++msgId,
      role: 'assistant',
      content: data.content || data.message || '抱歉，我暂时无法回答这个问题。',
    };
    messages.value.push(aiMsg);
  } catch (err) {
    messages.value.push({
      id: ++msgId,
      role: 'assistant',
      content: '抱歉，服务暂时不可用，请稍后再试。',
    });
  } finally {
    isTyping.value = false;
    scrollToBottom();
  }
}
</script>

