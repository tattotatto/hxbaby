# ==========================================
# 儿童大健康AI系统 - 环境变量配置
# 复制为 .env 并修改实际值
# ==========================================

# 数据库
DB_PASSWORD=hxbaby_dev
DATABASE_URL=postgresql://hxbaby:${DB_PASSWORD:-hxbaby_dev}@postgres:5432/hxbaby?sslmode=disable
MILVUS_HOST=milvus
MILVUS_PORT=19530
REDIS_URL=redis://redis:6379/0

# AI 服务 (Python)
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
LLM_MODEL=qwen-plus
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 业务服务 (Go)
BIZ_SERVICE_HOST=0.0.0.0
BIZ_SERVICE_PORT=8080
JWT_SECRET=change_me_in_production_to_random_64chars
AI_SERVICE_URL=http://ai-service:8001
CODEGEN_SERVICE_URL=http://codegen-service:3002

# 代码生成服务 (Node.js)
CODEGEN_SERVICE_PORT=3002

# MinIO / OSS 文件存储
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
OSS_ENDPOINT=minio:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=hxbaby
OSS_USE_SSL=false

# 微信 (生产环境配置)
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret
WX_MCH_ID=your_wechat_merchant_id
WX_MCH_API_KEY=your_wechat_mch_key

# 部署
BAAS_BASE_URL=http://biz-service:8080
ENVIRONMENT=production
LOG_LEVEL=info
